{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Tauri Dev",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "tauri",
                "dev"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "Generate Codebase Map",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "docs:code"
            ],
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false
            }
        },
        {
            "label": "Generate Database Docs",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "docs:db"
            ],
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false
            }
        },
        {
            "label": "Generate All Documentation",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Generate Codebase Map",
                "Generate Database Docs"
            ],
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true
            }
        }
    ]
}